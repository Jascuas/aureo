{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "figma-desktop": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "neon": {
      "type": "remote",
      "url": "https://mcp.neon.tech/mcp",
      "enabled": true
    }
  },
  "plugin": ["@tarquinen/opencode-dcp@latest"],
  "provider": {
    "ollama": {
      "models": {
        "llama3.1:8b": {
          "name": "Llama 3.1 8B (Remote)"
        },
        "qwen3.5:9b": {
          "name": "Qwen 3.5 9B (Remote)"
        },
        "glm-5.1:cloud": {
          "name": "GLM 5.1 Cloud (Remote)"
        }
      },
      "name": "Ollama Remote",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    },
    "github-copilot": {
      "models": {
        "claude-sonnet-4-6": {
          "options": {
            "thinking": {
              "type": "enabled"
            }
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        }
      }
    }
  }
}
